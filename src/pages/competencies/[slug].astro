---
import DetailPage from '../../components/DetailPage.astro';
import data from '../../data/CoreCompetencies.json';

export function getStaticPaths() {
  return data.items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
---

<DetailPage
  pageTitle={`${item.name} — Parody Mechanical Solutions LLC`}
  pageDesc={item.desc}
  kicker="Core competencies"
  backHref="/#competencies"
  title={item.name}
  intro={item.longDesc}
  itemsLabel="Scope"
  items={item.sub}
/>
