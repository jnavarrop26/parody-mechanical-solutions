---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="Page not found — Parody Mechanical Solutions LLC"
  description="The page you're looking for doesn't exist or was moved. Go back home or request a quote."
>
  <Header />
  <main id="top" class="notfound">
    <div class="wrap">
      <p class="eyebrow">Error 404</p>
      <h1 class="notfound__title" data-text="404">404</h1>
      <p class="notfound__stamp">Part not found</p>
      <p class="notfound__lede">
        The page you're looking for doesn't exist, was moved, or the link has
        a typo. Check the address or head back to the shop.
      </p>
      <div class="notfound__actions">
        <a class="btn btn-primary" href="/">Back to home</a>
        <a class="btn btn-ghost" href="/#services">See services</a>
        <a class="btn btn-ghost" href="/#contact">Contact us</a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .notfound {
    padding-block: clamp(4rem, 12vw, 9rem);
    border-bottom: 1px solid var(--line);
  }

  /* Mismo cartel con eco que el hero */
  .notfound__title {
    position: relative;
    margin-top: 1rem;
    font-family: var(--font-display);
    font-size: clamp(6rem, 24vw, 18rem);
    line-height: 0.9;
    letter-spacing: 0.01em;
    color: var(--enamel);
  }

  .notfound__title::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    transform: translate(0.05em, 0.04em);
    color: transparent;
    -webkit-text-stroke: 2px var(--rust);
    opacity: 0.5;
    z-index: -1;
    pointer-events: none;
  }

  /* Sello inclinado, como el de las páginas de detalle */
  .notfound__stamp {
    display: inline-block;
    margin-top: 1.75rem;
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
    border: 2px solid var(--ink);
    outline: 1px solid var(--ink);
    outline-offset: 3px;
    padding: 0.35em 0.8em;
    transform: rotate(-3deg);
  }

  .notfound__lede {
    margin-top: 1.75rem;
    max-width: 44ch;
    font-size: var(--fs-body);
    color: var(--ink-soft);
  }

  .notfound__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }
</style>
