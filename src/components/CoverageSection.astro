---
import data from '@/data/CoverageSection.json';

const { title, zones } = data;
---

<section id="coverage" class="coverage">
  <div class="wrap">
    <div class="coverage__head reveal">
      <h2 class="coverage__title">{title}</h2>
    </div>

    <div class="coverage__zones">
      {
        zones.map((z) => (
          <article class="coverage__zone reveal">
            <p class="coverage__response">{z.response}</p>
            <h3 class="coverage__name">{z.name}</h3>
            <p class="coverage__desc">{z.desc}</p>
          </article>
        ))
      }
    </div>


  </div>
</section>

<style>
  .coverage {
    padding-block: clamp(3rem, 8vw, 6rem);
    border-top: 1px solid var(--line);
  }

  .coverage__head {
    text-align: center;
  }

  /* Titular-cartel: las zonas se montan sobre la base de las letras */
  .coverage__title {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    line-height: 0.9;
    text-transform: uppercase;
    text-wrap: balance;
    color: var(--ink);
  }

  .coverage__zones {
    position: relative;
    z-index: 1;
    margin-top: clamp(1.75rem, 4vw, 3.5rem);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
  }

  /* El tiempo de respuesta manda: es lo que mira un coordinador de flota */
  .coverage__zone {
    display: grid;
    gap: 0.5rem;
    align-content: start;
    border-top: 2px solid var(--ink);
    padding-top: 1.1rem;
  }

  .coverage__response {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--rust-dark);
  }

  .coverage__name {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    line-height: 1.05;
    text-transform: uppercase;
    color: var(--ink);
  }

  .coverage__desc {
    color: var(--ink-soft);
    font-size: 1rem;
    max-width: 34ch;
  }

  .coverage__note {
    margin-top: clamp(2rem, 5vw, 3rem);
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    color: var(--steel);
    max-width: 56ch;
  }

  @media (max-width: 780px) {
    .coverage__zones {
      grid-template-columns: 1fr;
    }
  }
</style>
