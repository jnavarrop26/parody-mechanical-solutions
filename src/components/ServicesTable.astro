---
import TechDiagram from './TechDiagram.astro';
import data from '@/data/ServicesTable.json';

type Diagram = 'varilla' | 'disco' | 'amortiguador' | 'tacometro';

const { title, intro, categories } = data;
const themes = ['svc-max--enamel', 'svc-max--rust', 'svc-max--ink'];
---

<section id="services" class="services">
  <div class="wrap">
    <div class="services__head reveal">
      <h2 class="services__title">{title}</h2>
      {intro && <p class="services__intro">{intro}</p>}
    </div>

    <div class="services__panels">
      {
        categories.map((cat, i) => (
          <a
            class:list={['svc-max', 'reveal', themes[i % themes.length]]}
            href={`/services/${cat.slug}`}
          >
            <div class="svc-max__mark" aria-hidden="true">
              <TechDiagram variant={cat.diagram as Diagram} label={cat.mode} />
            </div>

            <div class="svc-max__lead">
              <h3 class="svc-max__name">{cat.name}</h3>
              <p class="svc-max__stamp">{cat.mode}</p>
            </div>

            <span class="svc-max__go">
              View service <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .services {
    padding-block: clamp(3rem, 8vw, 5.5rem);
    border-top: 1px solid var(--line);
  }

  .services__head {
    display: grid;
    gap: 0.6rem;
    justify-items: center;
    text-align: center;
  }

  /* Titular-cartel: los letreros se montan sobre la base de las letras */
  .services__title {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    line-height: 0.9;
    text-transform: uppercase;
    text-wrap: balance;
    color: var(--ink);
  }

  .services__intro {
    color: var(--ink-soft);
  }

  .services__panels {
    position: relative;
    z-index: 1;
    margin-top: clamp(1.75rem, 4vw, 3.5rem);
    display: grid;
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  /* ——— Letrero esmaltado compacto: todo el panel es el enlace ——— */

  .svc-max {
    position: relative;
    overflow: hidden;
    background: var(--panel-bg);
    color: var(--panel-fg);
    border: 2px solid var(--ink);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    padding-top: clamp(2rem, 4.5vw, 3rem);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: clamp(1.5rem, 4vw, 3rem);
    text-decoration: none;
    transition: transform 200ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .svc-max--enamel {
    --panel-bg: var(--enamel);
    --panel-fg: var(--paper);
    --panel-stripe: var(--rust);
  }

  /* Panel rojo de marca: blanco encima, la tinta oscura no daría contraste */
  .svc-max--rust {
    --panel-bg: var(--rust);
    --panel-fg: var(--paper);
    --panel-stripe: var(--ink);
  }

  .svc-max--ink {
    --panel-bg: var(--ink);
    --panel-fg: var(--paper);
    --panel-stripe: var(--rust);
  }

  /* Cinta de precaución en el borde superior */
  .svc-max::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 0.75rem;
    background: repeating-linear-gradient(
      -45deg,
      var(--panel-stripe) 0 10px,
      transparent 10px 20px
    );
  }

  /* Diagrama gigante como marca de agua */
  .svc-max__mark {
    position: absolute;
    right: -4%;
    bottom: -14%;
    width: clamp(200px, 24vw, 360px);
    color: var(--panel-fg);
    opacity: 0.13;
    transform: rotate(8deg);
    pointer-events: none;
  }

  .svc-max__mark :global(svg) {
    width: 100%;
  }

  .svc-max__mark :global(figcaption) {
    display: none;
  }

  .svc-max__lead {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1rem;
    justify-items: start;
  }

  .svc-max__name {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4.25rem);
    line-height: 0.92;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--panel-fg);
    max-width: 14ch;
  }

  /* Sello de caucho con el modo de operación */
  .svc-max__stamp {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--panel-fg);
    border: 2px solid var(--panel-fg);
    outline: 1px solid var(--panel-fg);
    outline-offset: 3px;
    padding: 0.35em 0.8em;
    transform: rotate(-3deg);
  }

  .svc-max__go {
    position: relative;
    z-index: 1;
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--panel-fg);
    border-bottom: 2px solid var(--panel-fg);
    padding-bottom: 0.3em;
  }

  .svc-max__go span {
    transition: transform 200ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  @media (hover: hover) and (pointer: fine) {
    .svc-max:hover {
      transform: translateY(-4px);
    }

    .svc-max:hover .svc-max__go span {
      transform: translateX(5px);
    }
  }

  @media (max-width: 720px) {
    .svc-max {
      flex-direction: column;
      align-items: flex-start;
    }

    .svc-max__mark {
      right: -16%;
      opacity: 0.09;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .svc-max,
    .svc-max__go span {
      transition: none;
    }

    .svc-max:hover {
      transform: none;
    }
  }
</style>
