---
import data from '../data/Hero.json';

const { title, lede, cta } = data;

/* Palabras indivisibles; el índice de letra corre a través de todas para el stagger */
let letterIndex = 0;
const words = title.split(' ').map((word) => ({
  letters: word.split('').map((ch) => ({ ch, i: letterIndex++ })),
}));
---

<section id="top" class="hero">
  <img
    class="hero__mark"
    src="/motor-combustion-interna.webp"
    alt=""
    aria-hidden="true"
    decoding="async"
  />

  <div class="wrap hero__grid">
    <h1 class="hero__title" data-text={title}>
      {words.map((word, wi) => (
        <Fragment>
          <span class="hero__word">
            {word.letters.map((l) => (
              <span class="hero__ch" style={`--i: ${l.i}`}>{l.ch}</span>
            ))}
          </span>
          {wi < words.length - 1 && ' '}
        </Fragment>
      ))}
    </h1>

    <div class="hero__foot">
      <p class="hero__lede">{lede}</p>
      <a class="btn btn-primary hero__cta" href={cta.href}>
        {cta.label}
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(3rem, 9vw, 6rem) clamp(3.5rem, 8vw, 6rem);
  }

  /* Marca de agua: plano técnico del motor. El dibujo viene en tinta sobre
     blanco; multiply funde el blanco con el papel y deja solo las líneas */
  .hero__mark {
    position: absolute;
    right: -2vw;
    top: 50%;
    width: clamp(300px, 48vw, 900px);
    max-height: 94%;
    object-fit: contain;
    mix-blend-mode: multiply;
    opacity: 0.14;
    transform: translateY(-50%) rotate(-6deg);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    align-content: space-between;
    row-gap: clamp(2rem, 5vw, 3.5rem);
    justify-items: start;
    min-height: min(70vh, 780px);
  }

  /* El título ES el hero: cartel a todo el ancho */
  .hero__title {
    position: relative;
    width: 100%;
    font-family: var(--font-display);
    font-size: var(--fs-hero);
    line-height: 0.9;
    letter-spacing: 0.01em;
    color: var(--ink);
    text-transform: uppercase;
    text-wrap: balance;
  }

  /* Cada palabra es indivisible; solo se parte entre palabras */
  .hero__word {
    display: inline-block;
    white-space: nowrap;
  }

  /* Squash & stretch: las letras caen estiradas hacia abajo y asientan */
  .hero__ch {
    display: inline-block;
    transform-origin: 50% 0;
    transform: translateY(0.12em) scaleY(2.1);
    opacity: 0;
    animation: hero-taffy 680ms cubic-bezier(0.23, 1, 0.32, 1) forwards;
    animation-delay: calc(var(--i) * 26ms);
  }

  @keyframes hero-taffy {
    0% {
      transform: translateY(0.12em) scaleY(2.1);
      opacity: 0;
    }
    55% {
      transform: translateY(0) scaleY(0.94);
      opacity: 1;
    }
    100% {
      transform: none;
      opacity: 1;
    }
  }

  /* Lede a la izquierda, CTA anclado a la derecha: la fila usa todo el ancho
     del cartel para que el botón no quede huérfano junto al texto */
  .hero__foot {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(1.5rem, 4vw, 3rem);
    flex-wrap: wrap;
  }

  /* En el hero el botón sube de escala: compite con el titular, no con el pie */
  .hero__cta {
    font-size: 0.9375rem;
    padding: 1.15em 2.1em;
  }

  .hero__cta span {
    transition: transform 0.2s ease;
  }

  .hero__cta:hover span {
    transform: translateX(4px);
  }

  /* Segunda pasada de tinta, corrida: se estampa al final */
  .hero__title::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    transform: translate(0.05em, 0.04em);
    color: transparent;
    -webkit-text-stroke: 2px var(--rust);
    opacity: 0;
    z-index: -1;
    pointer-events: none;
    animation: hero-stamp 400ms ease-out 750ms forwards;
  }

  @keyframes hero-stamp {
    to {
      opacity: 0.7;
    }
  }

  /* Tagline en dorado profundo: acento de marca, en caja y flujo normales */
  .hero__lede {
    max-width: 44ch;
    color: var(--rust-dark);
    font-weight: 500;
    font-size: clamp(1.125rem, 1.4vw, 1.3125rem);
    text-wrap: pretty;
  }

  @media (max-width: 720px) {
    .hero__mark {
      right: -14%;
      top: auto;
      bottom: 8%;
      width: clamp(240px, 68vw, 360px);
      transform: rotate(-6deg);
      opacity: 0.1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__cta span,
    .hero__cta:hover span {
      transition: none;
      transform: none;
    }

    .hero__ch {
      transform: none;
      opacity: 1;
      animation: none;
    }

    .hero__title::after {
      opacity: 0.7;
      animation: none;
    }
  }
</style>
