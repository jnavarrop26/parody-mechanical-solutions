---
import data from '../data/TestimonialsSection.json';

const { title, items } = data;
---

<section id="testimonios" class="testimonials">
  <div class="wrap">
    <div class="testimonials__head reveal">
      <h2 class="testimonials__title">{title}</h2>
    </div>

    <ul class="testimonials__list">
      {
        items.map((t) => (
          <li class="testimonials__item reveal">
            <blockquote class="testimonials__quote">
              <p>“{t.quote}”</p>
            </blockquote>
            <p class="testimonials__author">{t.author}</p>
            <p class="testimonials__detail">{t.detail}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .testimonials {
    padding-block: clamp(3rem, 8vw, 6rem);
    border-top: 1px solid var(--line);
  }

  .testimonials__head {
    display: grid;
    gap: 0.6rem;
    margin-bottom: clamp(2rem, 5vw, 3rem);
    max-width: 42ch;
  }

  .testimonials__title {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    line-height: 1;
    text-transform: uppercase;
    color: var(--ink);
  }

  .testimonials__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .testimonials__item {
    display: grid;
    gap: 0.75rem;
    align-content: start;
    border-top: 2px solid var(--rust);
    padding-top: 1.1rem;
  }

  .testimonials__quote {
    margin: 0;
  }

  .testimonials__quote p {
    color: var(--ink);
    font-size: 1.02rem;
    line-height: 1.55;
  }

  .testimonials__author {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--enamel);
  }

  .testimonials__detail {
    margin-top: -0.45rem;
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    color: var(--steel);
  }

  @media (max-width: 860px) {
    .testimonials__list {
      grid-template-columns: 1fr;
    }
  }
</style>
